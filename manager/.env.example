# Copy this to manager/.env and fill in your values.
# Run setup.sh at the repo root to have it filled in automatically.

SECRET_KEY=change-me-to-a-random-string
ADMIN_TOKEN=change-me-to-a-secret-token
FLAG_SECRET=change-me-flag-secret
HOST_IP=192.168.1.10
PORT_RANGE_START=8000

# ── Choose ONE of the CTF configs below ──────────────────────────────────────

# BankingAI CTF
CTF_COMPOSE_HOST_PATH=../challenge/docker-compose.yaml
CTF_CHALLENGE_DIR=/absolute/path/to/ctf/challenge
CTF_CONFIG_FILE=/ctf/config/bankingai.json
CTF_NAME=BankingAI CTF
WEB_SERVICE_NAME=web
STARTUP_TIMEOUT=180

# Task-1 CTF (comment out BankingAI block above and uncomment this)
# CTF_COMPOSE_HOST_PATH=../task-1/docker-compose.yml
# CTF_CHALLENGE_DIR=/absolute/path/to/ctf/task-1
# CTF_CONFIG_FILE=/ctf/config/task1.json
# CTF_NAME=SWOCTS — Task 1
# WEB_SERVICE_NAME=web
# STARTUP_TIMEOUT=30
